{
  "name": "n8n-nodes-autopost",
  "version": "0.1.5",
  "description": "n8n community node for AutoPost TheNextGen - Social media scheduling and inbox management",
  "keywords": [
    "n8n-community-node-package",
    "autopost",
    "social-media",
    "scheduling"
  ],
  "license": "MIT",
  "homepage": "https://autopost.thenextgen.ai",
  "author": "The Next Gen <admin@thenextgen.ai>",
  "repository": "https://github.com/UbaiSalih/n8n-nodes-autopost",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials package.json",
    "lintfix": "eslint nodes credentials package.json --fix",
    "prepublishOnly": "npm run build"
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/AutoPostApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/AutoPost/AutoPost.node.js"
    ]
  },
  "devDependencies": {
    "@types/node": "^18.19.130",
    "n8n-workflow": "^2.13.1",
    "typescript": "^5.9.3"
  }
}
